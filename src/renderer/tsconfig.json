{
  "compileOnSave": false,
  "compilerOptions": {
    "baseUrl": "./",
    "outDir": "./dist/out-tsc",
    "sourceMap": true,
    "declaration": false,
    "module": "ES2022",
    "moduleResolution": "bundler",
    "importHelpers": true,
    "target": "ES2022",
    "useDefineForClassFields": false,
    "experimentalDecorators": true,
    "strict": false,
    "strictPropertyInitialization": false,
    "ignoreDeprecations": "6.0",
    "typeRoots": ["node_modules/@types", "../types"],
    "lib": ["ES2022", "dom"]
  }
}
