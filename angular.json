{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "newProjectRoot": "src",
  "projects": {
    "renderer": {
      "projectType": "application",
      "schematics": {
        "@schematics/angular:component": {
          "inlineTemplate": true,
          "inlineStyle": true,
          "standalone": false
        }
      },
      "root": "src/renderer",
      "sourceRoot": "src/renderer/src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:application",
          "options": {
            "outputPath": "dist/renderer",
            "index": "src/renderer/src/index.html",
            "browser": "src/renderer/src/main.ts",
            "polyfills": [
              "zone.js"
            ],
            "tsConfig": "src/renderer/tsconfig.app.json",
            "assets": [
              "src/renderer/src/assets"
            ],
            "styles": [
              "src/renderer/src/styles.css",
              "src/renderer/src/assets/themes/_midleo.scss"
            ],
            "scripts": [],
            "baseHref": "./"
          },
          "configurations": {
            "production": {
              "fileReplacements": [
                {
                  "replace": "src/renderer/src/environments/environment.ts",
                  "with": "src/renderer/src/environments/environment.prod.ts"
                }
              ],
              "optimization": true,
              "outputHashing": "all",
              "sourceMap": false,
              "namedChunks": false,
              "extractLicenses": true,
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "2mb",
                  "maximumError": "5mb"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "8kb",
                  "maximumError": "16kb"
                }
              ]
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular-devkit/build-angular:dev-server",
          "configurations": {
            "production": {
              "buildTarget": "renderer:build:production"
            },
            "development": {
              "buildTarget": "renderer:build:development"
            }
          },
          "defaultConfiguration": "development"
        },
        "extract-i18n": {
          "builder": "@angular-devkit/build-angular:extract-i18n"
        },
        "test": {
          "builder": "@angular-devkit/build-angular:karma",
          "options": {
            "polyfills": [
              "zone.js",
              "zone.js/testing"
            ],
            "tsConfig": "src/renderer/tsconfig.spec.json",
            "assets": [
              "src/renderer/src/assets"
            ],
            "styles": [
              "src/renderer/src/styles.css"
            ],
            "scripts": []
          }
        }
      }
    }
  },
  "cli": {
    "analytics": false
  }
}
