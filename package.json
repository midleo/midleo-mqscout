{
  "name": "midleo-mqscout",
  "version": "4.0.0",
  "description": "Open-source desktop client for exploring IBM MQ queue managers",
  "author": "Midleo",
  "license": "GPL-3.0-or-later",
  "main": "./dist/main/main/main.js",
  "scripts": {
    "start": "cross-env-shell ELECTRON_RUN_AS_NODE= electron .",
    "build:dev:renderer": "ng build",
    "build:prod:renderer": "ng build --configuration production",
    "build:dev:main": "tsc -p src/main/tsconfig.json",
    "build:prod:main": "tsc -p src/main/tsconfig.json",
    "build:dev:preload": "webpack --config ./src/preload/webpack.config.cjs --mode development",
    "build:prod:preload": "webpack --config ./src/preload/webpack.config.cjs --mode production",
    "build:dev:all": "npm run build:dev:renderer && npm run build:dev:main && npm run build:dev:preload",
    "build:prod:all": "npm run build:prod:renderer && npm run build:prod:main && npm run build:prod:preload",
    "build:watch:renderer": "ng build --watch",
    "build:watch:main": "tsc -p src/main/tsconfig.json --watch",
    "build:watch:preload": "webpack --watch --config ./src/preload/webpack.config.cjs --mode development",
    "build:watch:all": "npm-run-all -p -r build:watch:renderer build:watch:main build:watch:preload",
    "lint": "ng lint",
    "test": "ng test --watch=false --browsers=ChromeHeadless",
    "package": "cross-env-shell ELECTRON_RUN_AS_NODE= npm run build:prod:all && electron-builder --dir",
    "release": "cross-env-shell ELECTRON_RUN_AS_NODE= npm run build:prod:all && electron-builder",
    "release:mac": "cross-env-shell ELECTRON_RUN_AS_NODE= npm run build:prod:all && electron-builder --mac",
    "release:win": "cross-env-shell ELECTRON_RUN_AS_NODE= npm run build:prod:all && electron-builder --win",
    "release:linux": "cross-env-shell ELECTRON_RUN_AS_NODE= npm run build:prod:all && electron-builder --linux"
  },
  "private": true,
  "dependencies": {
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^22.0.3",
    "@angular/animations": "^22.0.3",
    "@angular/cdk": "^22.0.3",
    "@angular/cli": "^22.0.3",
    "@angular/common": "^22.0.3",
    "@angular/compiler": "^22.0.3",
    "@angular/compiler-cli": "^22.0.3",
    "@angular/core": "^22.0.3",
    "@angular/forms": "^22.0.3",
    "@angular/material": "^22.0.3",
    "@angular/platform-browser": "^22.0.3",
    "@angular/platform-browser-dynamic": "^22.0.3",
    "@angular/router": "^22.0.3",
    "@types/jasmine": "^5.1.8",
    "@types/node": "^22.15.0",
    "@types/webpack": "^5.28.5",
    "cross-env": "^10.0.0",
    "electron": "^43.0.0",
    "electron-builder": "^26.0.12",
    "eslint": "^9.28.0",
    "jasmine-core": "^5.8.0",
    "karma": "^6.4.4",
    "karma-chrome-launcher": "^3.2.0",
    "karma-coverage": "^2.2.1",
    "karma-jasmine": "^5.1.0",
    "karma-jasmine-html-reporter": "^2.1.0",
    "npm-run-all": "^4.1.5",
    "rxjs": "^7.8.2",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tslib": "^2.8.1",
    "typescript": "^6.0.3",
    "webpack": "^5.99.9",
    "webpack-cli": "^6.0.1",
    "zone.js": "^0.16.0"
  },
  "build": {
    "appId": "com.midleo.mqscout",
    "productName": "Midleo MQScout",
    "copyright": "Copyright © Midleo",
    "directories": {
      "output": "release-builds",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "asar": true,
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "build/icon.png",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "icon": "build/icon.png",
      "target": [
        "nsis"
      ]
    },
    "linux": {
      "icon": "build/icon.png",
      "category": "Development",
      "target": [
        "AppImage",
        "deb"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "allowScripts": {
    "@parcel/watcher@2.5.6": true,
    "electron-winstaller@5.4.0": true,
    "esbuild@0.28.1": true,
    "esbuild@0.27.7": true,
    "fsevents@2.3.3": true,
    "lmdb@3.5.4": true,
    "msgpackr-extract@3.0.4": true
  }
}
